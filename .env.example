# Supabase (required for Phase 2+)
# Create a project at https://supabase.com and copy from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for `npm run supabase:db:push` (migrations). From Dashboard > Project Settings > Database > Database password
# SUPABASE_DB_PASSWORD=your-database-password
