# Supabase (required for Phase 2+)
# Create a project at https://supabase.com and copy from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for `npm run supabase:link` / migrations. From Dashboard > Project Settings > Database > Database password
# SUPABASE_DB_PASSWORD=your-database-password

# Optional: defaults to buhmynyqymryrjnqdiqt if unset
# SUPABASE_PROJECT_REF=your-project-ref

# Required for `npm run supabase:link` (Management API). Dashboard (top right) → Account → Access Tokens
# SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
